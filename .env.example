# =====================================================================
# .env — Konfigurasi AI Outreach Automation
# Salin file ini jadi .env lalu isi nilainya.
# Semua konfigurasi dibaca dari sini lewat agents/config.py
# =====================================================================

# ── Groq API (WAJIB) ─────────────────────────────────────────────────
# Daftar gratis di https://console.groq.com/keys
GROQ_API_KEY=

# ── Portfolio ─────────────────────────────────────────────────────────
# Link contoh website yang pernah lo bikin — Groq akan selipin di pesan
# Contoh: https://mybabygroup.com
PORTFOLIO_URL=

# ── Telegram (opsional) ───────────────────────────────────────────────
# Notif otomatis saat ada lead yang reply atau build selesai.
# Setup:
#   1. Chat @BotFather → /newbot → dapat TOKEN
#   2. Kirim pesan ke bot, buka: https://api.telegram.org/bot<TOKEN>/getUpdates
#      → ambil "id" dari field "chat" = CHAT_ID lo
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Target Outreach ───────────────────────────────────────────────────
# Kota-kota yang jadi target (pisah koma). Default: Berau
# Contoh multi-kota: KOTA_TARGET=Berau,Bulungan,Malinau
KOTA_TARGET=Berau

# Kategori default untuk scraper kalau tidak di-override CLI
DEFAULT_KATEGORI=klinik swasta

# ── Behavior ──────────────────────────────────────────────────────────
# Hari sebelum lead "sent" ditandai followup_due (default: 3)
HARI_BATAS_FOLLOWUP=3

# Threshold fuzzy dedup nama bisnis: 0.0–1.0 (default: 0.80)
FUZZY_THRESHOLD=0.80

# Batas panggilan Groq API per run builder (safety cap, default: 40)
GROQ_MAX_CALLS_PER_RUN=40

# Self-critique pesan (#18) — validasi kualitas pesan sebelum disimpan
# Matikan (false) kalau kuota Groq mepet — setiap pesan butuh 1 API call ekstra
# Skor minimum 1-10: pesan di bawah skor ini di-regenerate (maks RETRY kali)
SELF_CRITIQUE_ENABLED=false
SELF_CRITIQUE_MIN_SKOR=7
SELF_CRITIQUE_MAX_RETRY=2

# Generate ke draft dulu (true) atau langsung pending (false, default)
DRAFT_MODE_DEFAULT=false

# ── Server & Logging ──────────────────────────────────────────────────
# Port dashboard lokal (default: 8000)
PORT_DASHBOARD=8000

# Level log: DEBUG / INFO / WARNING (default: INFO)
LOG_LEVEL=INFO

# ── Orchestrator (decision loop otonom, opsional) ───────────────────────
# Kalau true: selama bot Telegram (python main.py bot) nyala, sistem otomatis
# build harian + cek follow-up sendiri tanpa perlu Task Scheduler terpisah.
# Default false — behavior lama (manual/Task Scheduler) tidak berubah kalau
# baris ini dibiarkan false atau tidak diisi sama sekali.
ORCHESTRATOR_ENABLED=false

# Interval cek kondisi sistem, dalam detik (default: 1800 = 30 menit)
ORCHESTRATOR_CEK_INTERVAL=1800

# Jam build harian otomatis, format HH:MM 24 jam (default: 06:00)
ORCHESTRATOR_JAM_BUILD=06:00
